# Central server environment variables
# Copy to .env and fill in real values

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
# Option A: Docker PostgreSQL on the same server (testing)
#   DATABASE_URL=postgresql+psycopg2://arbitr:arbitr@localhost:5432/arbitr
#
# Option B: Managed PostgreSQL (Timeweb, Yandex Cloud, etc.)
#   DATABASE_URL=postgresql+psycopg2://arbitr:YOUR_PASSWORD@your-pg-host:5432/arbitr
DATABASE_URL=postgresql+psycopg2://arbitr:CHANGE_ME@localhost:5432/arbitr

# ------------------------------------------------------------------
# S3 / Object Storage (for PDFs — leave empty for first test)
# ------------------------------------------------------------------
# Option A: External S3 provider (Timeweb, Yandex, Selectel)
#   S3_ENDPOINT=s3.timeweb.cloud
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...
#   S3_BUCKET=arbitr-pdfs
#   S3_REGION=ru-1
#   S3_SECURE=true
#
# Option B: MinIO (self-hosted, included in docker-compose.yml)
#   Set only MINIO_SECRET_KEY. Orchestrator will use MinIO automatically.

# External S3 (primary — overrides MinIO if endpoint is set)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=arbitr-pdfs
S3_REGION=ru-1
S3_SECURE=true

# MinIO fallback (legacy / local dev)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=arbitr-admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET
MINIO_BUCKET=arbitr-pdfs
MINIO_SECURE=false

# ------------------------------------------------------------------
# Orchestrator API key (workers use this to authenticate)
# ------------------------------------------------------------------
API_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_32_CHARS_MIN

# ------------------------------------------------------------------
# Timeweb Cloud API (for automatic IP rotation — leave empty for first test)
# ------------------------------------------------------------------
TIMEWEB_API_TOKEN=

# ------------------------------------------------------------------
# Rotation rate limits (optional — defaults are sensible)
# ------------------------------------------------------------------
ROTATION_MAX_PER_HOUR=3
ROTATION_MAX_PER_DAY=10
ROTATION_COOLDOWN_MINUTES=15
ROTATION_COMMAND_EXPIRY_MINUTES=30

# ------------------------------------------------------------------
# Worker monitoring (optional — defaults are sensible)
# ------------------------------------------------------------------
HEARTBEAT_TIMEOUT_MINUTES=10
WORKER_HEARTBEAT_TIMEOUT_MINUTES=5
MONITOR_INTERVAL_SECONDS=60

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
