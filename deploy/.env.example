# Central server environment variables
# Copy to .env and fill in real values

# ------------------------------------------------------------------
# Database (Managed PostgreSQL via Timeweb or other provider)
# ------------------------------------------------------------------
PG_HOST=your-managed-pg-host.timeweb.cloud
PG_PORT=5432
PG_DATABASE=arbitr
PG_USER=arbitr
PG_PASSWORD=CHANGE_ME

# ------------------------------------------------------------------
# S3 / Object Storage (for PDFs)
# ------------------------------------------------------------------
# Option A: External S3 provider (recommended — Timeweb, Yandex, Selectel)
#   Set S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY to use external S3.
#   S3_ENDPOINT=s3.timeweb.cloud
#   S3_ACCESS_KEY=...
#   S3_SECRET_KEY=...
#   S3_BUCKET=arbitr-pdfs
#   S3_REGION=ru-1
#   S3_SECURE=true
#
# Option B: MinIO (self-hosted, included in docker-compose.yml)
#   Set only MINIO_SECRET_KEY. Orchestrator will use MinIO automatically.
#   MinIO is bound to 80GB SSD on the central server — NOT suitable for
#   production scale. Use external S3 for 20M+ cases.

# External S3 (primary — overrides MinIO if set)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=arbitr-pdfs
S3_REGION=ru-1
S3_SECURE=true

# MinIO (legacy / local dev)
MINIO_ACCESS_KEY=arbitr-admin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET

# ------------------------------------------------------------------
# Orchestrator API key (workers use this to authenticate)
# ------------------------------------------------------------------
API_KEY=CHANGE_ME_LONG_RANDOM_STRING

# ------------------------------------------------------------------
# Timeweb Cloud API (for automatic IP rotation)
# ------------------------------------------------------------------
TIMEWEB_API_TOKEN=CHANGE_ME_TIMEWEB_TOKEN

# ------------------------------------------------------------------
# Rotation rate limits (optional — defaults are sensible)
# ------------------------------------------------------------------
ROTATION_MAX_PER_HOUR=3
ROTATION_MAX_PER_DAY=10
ROTATION_COOLDOWN_MINUTES=15
ROTATION_COMMAND_EXPIRY_MINUTES=30

# ------------------------------------------------------------------
# Worker monitoring (optional — defaults are sensible)
# ------------------------------------------------------------------
HEARTBEAT_TIMEOUT_MINUTES=10
WORKER_HEARTBEAT_TIMEOUT_MINUTES=5
MONITOR_INTERVAL_SECONDS=60

# ------------------------------------------------------------------
# Server
# ------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
